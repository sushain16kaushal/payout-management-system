generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SaleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  ADVANCE
  FINAL_ADJUSTMENT
  WITHDRAWAL
}

enum TransactionStatus {
  INITIATED
  SUCCESS
  FAILED
  CANCELLED
  REJECTED
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  walletBalance    Decimal   @default(0) @db.Decimal(12, 2)
  lastWithdrawalAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sales        Sale[]
  transactions PayoutTransaction[]

  @@index([lastWithdrawalAt])
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  sales Sale[]
}

model Sale {
  id             String     @id @default(uuid())
  userId         String
  brandId        String
  earning        Decimal    @db.Decimal(12, 2)
  status         SaleStatus @default(PENDING)
  advancePaid    Boolean    @default(false)
  advanceAmount  Decimal    @default(0) @db.Decimal(12, 2)
  reconciledAt   DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  brand Brand @relation(fields: [brandId], references: [id])

  transactions PayoutTransaction[]

  @@index([userId, status])
  @@index([userId, advancePaid])
}

model PayoutTransaction {
  id        String             @id @default(uuid())
  userId    String
  saleId    String?
  type      TransactionType
  amount    Decimal            @db.Decimal(12, 2)
  status    TransactionStatus  @default(INITIATED)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User  @relation(fields: [userId], references: [id])
  sale Sale? @relation(fields: [saleId], references: [id])

  @@index([userId, type])
  @@index([userId, status])
  @@index([saleId])
}